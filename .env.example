# SLATE Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# EXCHANGE API CONFIGURATION
# ============================================================================

# Binance Futures API (USDT-M Perpetuals)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

# Bitget Perpetual Futures API
BITGET_API_KEY=your_bitget_api_key_here
BITGET_API_SECRET=your_bitget_api_secret_here
BITGET_PASSPHRASE=your_bitget_passphrase_here
BITGET_TESTNET=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=slate_trading
POSTGRES_USER=slate_user
POSTGRES_PASSWORD=your_postgres_password_here

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Server Configuration
SLATE_HOST=0.0.0.0
# Port 8788 avoids conflict with ASTRA running on 8787
SLATE_PORT=8788
SLATE_ENV=development
SLATE_LOG_LEVEL=INFO

# Trading Mode: paper, live_small, live_full
SLATE_TRADING_MODE=paper

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# Portfolio Limits
RISK_MAX_GROSS_EXPOSURE=3.0
RISK_MAX_NET_EXPOSURE=1.0
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_MAX_CORRELATION=0.8
RISK_MIN_LIQUIDITY_USD=1000000

# Position Sizing
POSITION_SIZING_METHOD=fractional_kelly
POSITION_KELLY_FRACTION=0.25
POSITION_MAX_PCT=0.1

# ============================================================================
# STRATEGY DISCOVERY
# ============================================================================

# Discovery Configuration
DISCOVERY_ENABLED=true
DISCOVERY_INTERVAL_SECONDS=3600
DISCOVERY_MIN_CONFIDENCE=0.7
DISCOVERY_MIN_SHARPE=0.5
DISCOVERY_MIN_WIN_RATE=0.55
DISCOVERY_MAX_STRATEGIES_LIVE=20

# ============================================================================
# EXECUTION
# ============================================================================

# Execution Configuration
EXECUTION_MAX_SLIPPAGE_PCT=0.05
EXECUTION_ORDER_TIMEOUT_SECONDS=30
EXECUTION_RETRY_ATTEMPTS=3

# ============================================================================
# MONITORING
# ============================================================================

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_METRICS_PORT=9090
MONITORING_DASHBOARD_PORT=3000

# Alert Configuration
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@slate.com
ALERT_EMAIL_TO=your_email@example.com
ALERT_EMAIL_USERNAME=your_email@example.com
ALERT_EMAIL_PASSWORD=your_email_password

# ============================================================================
# SECURITY
# ============================================================================

# Security Configuration
SECURITY_VAULT_ENABLED=false
SECURITY_VAULT_ADDR=http://localhost:8200
SECURITY_VAULT_TOKEN=your_vault_token_here

# ============================================================================
# TRADINGVIEW / PINE SCRIPT
# ============================================================================

# TradingView Configuration (for Pine Script export)
TRADINGVIEW_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TRADINGVIEW_ENABLED=false

# ============================================================================
# HAAS ONLINE / HAASSCRIPT
# ============================================================================

# HaasOnline Configuration
HAAS_ONLINE_API_URL=http://localhost:9000
HAAS_ONLINE_API_KEY=your_haas_online_api_key
HAAS_ONLINE_SECRET=your_haas_online_secret
HAAS_ONLINE_ENABLED=false

# ============================================================================
# LOGGING
# ============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/slate.log
LOG_ROTATION=true
LOG_RETENTION_DAYS=30

# ============================================================================
# DEVELOPMENT / TESTING
# ============================================================================

# Development Settings
DEBUG=false
TEST_MODE=false
MOCK_EXCHANGE=false

# ============================================================================
# BACKUP
# ============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# ============================================================================
# GRAPHPALACE INTEGRATION
# ============================================================================

# GraphPalace Memory Palace Configuration
GRAPHPALACE_ENABLED=true
GRAPHPALACE_PATH=./palace_data
GRAPHPALACE_DECAY_RATE=0.05
GRAPHPALACE_MAX_DRAWERS=500
